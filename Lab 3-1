import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

# Load dataset
canada_df = pd.read_csv("canada_per_capita_income.csv")

# Check for missing values (if any)
canada_df = canada_df.dropna()

# Create Linear Regression model
model = LinearRegression()
model.fit(canada_df[['year']], canada_df['per capita income (US$)'])

# Predict income for year 2020
prediction = model.predict(pd.DataFrame({'year': [2020]}))

print("Predicted Per Capita Income in 2020:", prediction[0])

# Plot graph
plt.figure()
plt.scatter(canada_df['year'], canada_df['per capita income (US$)'])
plt.plot(canada_df['year'], model.predict(canada_df[['year']]))
plt.xlabel("Year")
plt.ylabel("Per Capita Income (US$)")
plt.title("Canada Per Capita Income Prediction")
plt.show()
